# ─── Alera Supabase Configuration ────────────────────────────────────────────
# Copy this file to .env and fill in your project values.
# Get these from: https://app.supabase.com → your project → Settings → API
#
# NEVER commit .env to git. It is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Paystack (card payments) ─────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developers
# Use TEST key during development (starts with pk_test_)
# Switch to LIVE key (pk_live_) only when going to production
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# ─── Termii (SMS receipts) ────────────────────────────────────────────────────
# Get from: https://termii.com → Dashboard → API Keys
# Nigerian SMS gateway, supports generic + DND-whitelisted channels
VITE_TERMII_API_KEY=your_termii_api_key_here
